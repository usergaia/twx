# Copy to .env and edit for a public (EC2) deploy. .env is gitignored.
# Local development needs NONE of this — the compose defaults already point at
# localhost. These values only matter when the app is reached over a public
# host/IP or domain.
#
# Replace YOUR_HOST with your EC2 public IP (e.g. 203.0.113.10) or domain.
# Use https:// instead of http:// once you put a TLS reverse proxy in front.

# --- FastAPI CORS: which browser origin(s) may call the AI directly ---
# Must match the address the FE is served from. Comma-separated for multiple.
CORS_ORIGINS=http://YOUR_HOST:3000

# --- Browser-facing upstream URLs baked into the FE bundle at build time ---
# These are what the user's browser hits, so they must be the PUBLIC addresses
# (NOT compose service DNS). Changing them requires `docker compose up --build`.
NEXT_PUBLIC_AI_URL=http://YOUR_HOST:8001
NEXT_PUBLIC_N8N_URL=http://YOUR_HOST:5678

# --- n8n public addressing (so generated webhook URLs use the right host) ---
N8N_HOST=YOUR_HOST
N8N_PROTOCOL=http
WEBHOOK_URL=http://YOUR_HOST:5678/

# --- Misc ---
GENERIC_TIMEZONE=Asia/Manila
